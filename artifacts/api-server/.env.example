PORT=3001
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-5.4-mini
CORS_ORIGIN=https://vemat.netlify.app,https://www.vemat.ma

# Supabase — used to validate JWTs from the portail front-end
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Cloud Storage — internal catalogues
GCS_BUCKET=vemat-catalogues
# Local dev (path to JSON service-account key, gitignored):
GCS_KEY_PATH=./secrets/gcs-key.json
# Prod (one-line JSON or base64 of the same file):
# GCS_KEY_JSON='{"type":"service_account",...}'
